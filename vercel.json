{
  "rewrites": [
    { "source": "/api/db-token", "destination": "/api/db-token" },
    { "source": "/api/user-data", "destination": "/api/user-data" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/reset-password", "destination": "/api/reset-password" },
    { "source": "/api/google-login", "destination": "/api/google-login" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
